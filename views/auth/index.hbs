<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>Auth</title>
  </head>
  <body>
    <form id="form">
      <legend>EZ-shops</legend>
      <input type="text" name="email" placeholder="Email">
      <input type="password" name="password" placeholder="Password">
      <button type="submit">Login</button>
    </form>
    <script>
      const form = document.querySelector('#form');
      form.addEventListener('submit', async (event) => {
        event.preventDefault();

        const email = event.target[0].value;
        const password = event.target[1].value;

        try {
          const response = await fetch("/auth/login", {
            method: "POST",
            headers: {
              "Content-Type": "application/json"
            },
            body: JSON.stringify({
              email,
              password
            })
          });

          const data = await response.json();

          if (response.status === 200) {
            const redirectTo = new URLSearchParams(new URL(window.location.href).search).get('from');
            window.location.href = `${window.location.origin}/${redirectTo ?? 'api'}`;
          } else if (data.errors?.length > 0) {
            data.errors.forEach((error) => {
              const firstKey = Object.keys(error.constraints)[0];
              const firstError = error.constraints[firstKey];
              if (firstError) alert(firstError);
            });
          } else {
            alert(data.message);
          }
        } catch (error) {
          console.error('Error:', error);
        }
      });

    </script>
  </body>
  <style>
    html {
      font-family: Arial, Helvetica, sans-serif;
      color: black;
    }
    legend {
      font-weight: 600;
    }
    body {
      height: 100vh;
    }
    form {
      width: 100%;
      height: 100%;
      margin: 0 auto;
      max-width: 290px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    input {
      margin-top: 10px;
      height: 18px;
    }
    button {
      height: 24px;
      margin-top: 10px;
      cursor: pointer;
    }
  </style>
</html>